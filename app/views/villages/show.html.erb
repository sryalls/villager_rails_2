<%= link_to 'Home', root_path %>
<h1><%= current_user.username %>'s Village</h1>
<p>Welcome to your village, <%= current_user.username %>!</p>
<h2>Resources</h2>
<div id="resources-list">
  <%= render 'villages/resources_list', village_resources: @village.village_resources %>
</div>
<%= render 'build_form', village: @village, buildings: @buildings %>
<%= render 'built_buildings', buildings: @village.buildings %>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    function pollResources() {
      fetch("<%= resources_stream_village_path(@village, format: :turbo_stream) %>")
        .then(response => response.text())
        .then(html => Turbo.renderStreamMessage(html));
    }
    setInterval(pollResources, 1000);
  });
</script>